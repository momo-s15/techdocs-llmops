# Paths (non-secret). Use forward slashes or escaped backslashes on Windows.
CHROMA_PERSIST_DIR=./data/chroma
MANUALS_DIR=./data/manuals
CHROMA_COLLECTION_NAME=techdocs_v1

# Embeddings (local HuggingFace / sentence-transformers; no API key)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Ollama (local). OLLAMA_MODEL must match a name from: ollama list (often includes :latest)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:latest

# Retrieval
DEFAULT_TOP_K=4

# API
ENABLE_REINDEX_API=false
LOG_LEVEL=INFO

# Ollama CUDA: this file does not fix GPU errors. See README — use Windows env (e.g. setx CUDA_VISIBLE_DEVICES "-1") and restart Ollama.
